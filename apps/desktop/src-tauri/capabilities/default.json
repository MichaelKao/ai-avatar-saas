{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the AI Avatar Desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://*.railway.app/**"
        },
        {
          "url": "https://*.runpod.net/**"
        },
        {
          "url": "https://*.proxy.runpod.net/**"
        }
      ]
    }
  ]
}
